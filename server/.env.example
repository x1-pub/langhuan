# 请在同级目录创建文件 .env 并正确配置 DATABASE_URL

# 服务启动配置（可选）
SERVER_HOST=0.0.0.0
SERVER_PORT=7209

# CORS 白名单（可选）
# 为空或 "*" 表示允许所有来源（仅建议本地开发）
# 多个来源用英文逗号分隔
# CORS_ORIGINS=http://localhost:5173,https://example.com
CORS_ORIGINS=*

# 元数据库配置（用于存储连接信息）
DATABASE_URL=mysql://username:password@localhost:3306/dbname

# 开发环境模拟登录用户（生产环境不要配置）
DEV_USER_ID=10001
